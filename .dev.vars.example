# Copy to `.dev.vars` for local `wrangler pages dev`. Never commit the real file.
# These are the Cloudflare Turnstile TEST keys (always pass) — safe for local dev.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Resend — get a key at https://resend.com. Free tier: 100/day, 3000/mo.
RESEND_API_KEY=re_your_key_here

# Where inquiry emails go, and the verified sender (Resend needs SPF/DKIM/DMARC).
CONTACT_TO_EMAIL=you@example.com
CONTACT_FROM_EMAIL=Your Name <hello@yourdomain.com>
