---
interface Props {
  kicker?: string;
  title: string;
  class?: string;
  align?: "left" | "center";
}
const { kicker, title, class: className = "", align = "left" } = Astro.props;
const alignCls = align === "center" ? "text-center items-center" : "text-left items-start";
---

<div class:list={["flex flex-col gap-3", alignCls, className]}>
  {
    kicker && (
      <span class="text-accent-deep text-xs font-medium uppercase tracking-[0.22em]">
        {kicker}
      </span>
    )
  }
  <h2 class="text-3xl sm:text-4xl md:text-5xl max-w-2xl text-balance">{title}</h2>
</div>
