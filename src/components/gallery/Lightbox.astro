---
// A single accessible lightbox per page. It operates on any button marked
// [data-lightbox-item] with data-full / data-alt / data-caption attributes.
---

<div
  id="lightbox"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/92"
  role="dialog"
  aria-modal="true"
  aria-label="Photo viewer"
>
  <button type="button" data-lb-close class="absolute right-4 top-4 p-2 text-white/80 hover:text-white" aria-label="Close viewer">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" /></svg>
  </button>

  <button type="button" data-lb-prev class="absolute left-2 top-1/2 -translate-y-1/2 p-3 text-white/80 hover:text-white sm:left-6" aria-label="Previous photo">
    <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
  </button>
  <button type="button" data-lb-next class="absolute right-2 top-1/2 -translate-y-1/2 p-3 text-white/80 hover:text-white sm:right-6" aria-label="Next photo">
    <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M9 6l6 6-6 6" /></svg>
  </button>

  <figure class="flex max-h-[88svh] max-w-[92vw] flex-col items-center">
    <img data-lb-img src="" alt="" class="max-h-[80svh] max-w-full object-contain" />
    <figcaption class="mt-3 flex items-center gap-3 text-sm text-white/70">
      <span data-lb-counter></span>
      <span data-lb-caption></span>
    </figcaption>
  </figure>
</div>

<script>
  function initLightbox() {
    const lb = document.getElementById("lightbox");
    if (!lb || lb.dataset.ready === "true") return;
    lb.dataset.ready = "true";

    const img = lb.querySelector<HTMLImageElement>("[data-lb-img]");
    const caption = lb.querySelector<HTMLElement>("[data-lb-caption]");
    const counter = lb.querySelector<HTMLElement>("[data-lb-counter]");
    const items = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-lightbox-item]"),
    );
    if (!img || items.length === 0) return;

    let index = 0;
    let lastFocus: HTMLElement | null = null;

    const show = (i: number) => {
      index = (i + items.length) % items.length;
      const el = items[index];
      img.src = el.dataset.full ?? "";
      img.alt = el.dataset.alt ?? "";
      const cap = el.dataset.caption ?? "";
      if (caption) caption.textContent = cap;
      if (counter) counter.textContent = `${index + 1} / ${items.length}`;
    };

    const open = (i: number) => {
      lastFocus = document.activeElement as HTMLElement;
      show(i);
      lb.classList.remove("hidden");
      lb.classList.add("flex");
      document.body.style.overflow = "hidden";
      lb.querySelector<HTMLButtonElement>("[data-lb-close]")?.focus();
    };

    const close = () => {
      lb.classList.add("hidden");
      lb.classList.remove("flex");
      document.body.style.overflow = "";
      lastFocus?.focus();
    };

    items.forEach((el, i) => el.addEventListener("click", () => open(i)));
    lb.querySelector("[data-lb-close]")?.addEventListener("click", close);
    lb.querySelector("[data-lb-next]")?.addEventListener("click", () => show(index + 1));
    lb.querySelector("[data-lb-prev]")?.addEventListener("click", () => show(index - 1));
    lb.addEventListener("click", (e) => {
      if (e.target === lb) close();
    });

    document.addEventListener("keydown", (e) => {
      if (lb.classList.contains("hidden")) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowRight") show(index + 1);
      if (e.key === "ArrowLeft") show(index - 1);
      if (e.key === "Tab") {
        // Simple focus trap: keep focus on the close button.
        e.preventDefault();
        lb.querySelector<HTMLButtonElement>("[data-lb-close]")?.focus();
      }
    });
  }

  document.addEventListener("astro:page-load", initLightbox);
</script>
