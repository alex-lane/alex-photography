---
import { Image, getImage } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  /** `sizes` attribute — get this right or mobile Lighthouse suffers. */
  sizes?: string;
  widths?: number[];
  class?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "auto";
  /** e.g. "3 / 4" — reserves space and prevents layout shift. */
  aspect?: string;
}

const {
  src,
  alt,
  sizes = "100vw",
  widths = [480, 960, 1440, 2000],
  class: className = "",
  loading = "lazy",
  fetchpriority = "auto",
  aspect,
} = Astro.props;

// Tiny blurred placeholder, shown through the transparent <img> until it paints.
const lqip = await getImage({ src, width: 24, quality: 30 });
---

<div
  class:list={["ri", className]}
  style={aspect ? `aspect-ratio:${aspect}` : undefined}
>
  <img src={lqip.src} alt="" aria-hidden="true" class="ri__lqip" />
  <Image
    src={src}
    alt={alt}
    widths={widths}
    sizes={sizes}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
    class="ri__img"
  />
</div>

<style>
  .ri {
    position: relative;
    overflow: hidden;
    background: var(--color-bone-deep);
  }
  .ri__lqip {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.06);
    filter: blur(14px);
  }
  .ri__img {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
