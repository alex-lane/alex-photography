---
import Container from "../ui/Container.astro";
import SectionHeading from "../ui/SectionHeading.astro";

const steps = [
  {
    n: "01",
    title: "Say hello",
    body: "Send a quick inquiry with what you have in mind. I reply within a day.",
  },
  {
    n: "02",
    title: "Plan it together",
    body: "We settle on the vibe, location, and timing over a short call or email.",
  },
  {
    n: "03",
    title: "The session",
    body: "Relaxed and unhurried. I direct just enough so you can forget the camera.",
  },
  {
    n: "04",
    title: "Your gallery",
    body: "Hand-edited images arrive in a private gallery, ready to download and print.",
  },
];
---

<section class="py-[var(--spacing-section)]">
  <Container>
    <SectionHeading kicker="How it works" title="Booking is the easy part." />
    <ol class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((s) => (
          <li class="border-line border-t pt-5" data-reveal>
            <span class="text-accent-deep font-display text-3xl">{s.n}</span>
            <h3 class="mt-3 text-xl">{s.title}</h3>
            <p class="text-ink-soft mt-2 text-sm leading-relaxed">{s.body}</p>
          </li>
        ))
      }
    </ol>
  </Container>
</section>
